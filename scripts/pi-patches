#!/usr/bin/env bash
set -euo pipefail

REPO="${1:-$HOME/.local/share/pi-mono}"
PATCHES_DIR="${2:-$HOME/.pi/agent/patches}"

if [[ ! -d "$REPO/.git" ]]; then
  echo "pi-mono not found at $REPO" >&2
  exit 1
fi

cd "$REPO"

if [[ ! -d "$PATCHES_DIR" ]]; then
  echo "No patches directory at $PATCHES_DIR"
  echo "Patches: none"
  exit 0
fi

shopt -s nullglob
patches=("$PATCHES_DIR"/*.patch)
if (( ${#patches[@]} == 0 )); then
  echo "No patch files found in $PATCHES_DIR"
  echo "Patches: none"
  exit 0
fi

echo "Patches available at $PATCHES_DIR:"
for patch in "${patches[@]}"; do
  name="$(basename "$patch")"
  if git apply --check "$patch" 2>/dev/null; then
    echo "  ✅ $name  (applies cleanly)"
  elif git apply --reverse --check "$patch" 2>/dev/null; then
    echo "  ✅ $name  (already present)"
  else
    echo "  ❌ $name  (NEEDS RECONCILIATION — upstream likely changed)"
  fi
done
cat <<'EOF'

Action required: review each patch above.
  - ✅ applies cleanly = available for a clean upstream checkout
  - ✅ already present = active in this checkout
  - ❌ = regenerate patch or drop if superseded
EOF
