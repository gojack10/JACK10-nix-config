#!/usr/bin/env bash
set -euo pipefail

REPO="$HOME/.local/share/pi-mono"
BASELINE="$REPO/.audit-baseline.txt"
PATCHES_DIR="$HOME/.pi/agent/patches"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
NODE_BIN="${PI_NODE:-node}"
NPM_BIN="npm"
if command -v mise >/dev/null 2>&1; then
  NODE_BIN="mise exec node@24 -- node"
  NPM_BIN="mise exec node@24 -- npm"
elif [[ -x "$HOME/.local/bin/mise" ]]; then
  NODE_BIN="$HOME/.local/bin/mise exec node@24 -- node"
  NPM_BIN="$HOME/.local/bin/mise exec node@24 -- npm"
fi

load_jack10_ssh_env() {
  local helper
  for helper in \
    "${JACK10_SSH_ENV_HELPER:-}" \
    "$HOME/.local/share/JACK10-nix-config/ssh-env.sh" \
    "$HOME/.config/JACK10-nix-config/scripts/lib/ssh-env.sh"; do
    if [[ -n "$helper" && -r "$helper" ]]; then
      # shellcheck disable=SC1090
      . "$helper"
      jack10_load_ssh_env
      return 0
    fi
  done
}

load_jack10_ssh_env

if [[ ! -d "$REPO/.git" ]]; then
  echo "pi-mono not found at $REPO" >&2
  exit 1
fi

cd "$REPO"

# ── Helpers ──────────────────────────────────────────────────────────

write_pi_launcher() {
  local launcher="$HOME/.local/bin/pi"
  mkdir -p "$(dirname "$launcher")"
  cat > "$launcher" <<'EOF'
#!/usr/bin/env bash
# pi — launcher using compiled JS from the local checkout.
REPO="$HOME/.local/share/pi-mono"
CLI="$REPO/packages/coding-agent/dist/cli.js"
export PI_PACKAGE_DIR="$REPO/packages/coding-agent"
NODE_BIN="${PI_NODE:-node}"
if command -v mise >/dev/null 2>&1; then
	NODE_BIN="mise exec node@24 -- node"
elif [[ -x "$HOME/.local/bin/mise" ]]; then
	NODE_BIN="$HOME/.local/bin/mise exec node@24 -- node"
fi

exec $NODE_BIN "$CLI" "$@"
EOF
  chmod +x "$launcher"
}

needs_rebuild() {
  [[ ! -d "$REPO/node_modules" ]] && return 0
  [[ ! -f "$REPO/node_modules/undici/package.json" ]] && return 0
  [[ ! -f "$REPO/packages/coding-agent/dist/cli.js" ]] && return 0
  return 1
}

install_and_build() {
  echo "Installing locked deps (--ignore-scripts blocks third-party install hooks)..."
  $NPM_BIN ci --ignore-scripts --silent

  echo "Building workspace packages..."
  $NPM_BIN run build --silent
}

update_pi_packages() {
  local pi_bin="$HOME/.local/bin/pi"
  if [[ ! -x "$pi_bin" ]]; then
    echo "pi launcher not found at $pi_bin" >&2
    return 1
  fi

  echo "Updating pi packages..."
  "$pi_bin" update --extensions --no-approve
}

ghsa_ids_from_audit() {
  { $NPM_BIN audit --json 2>/dev/null || true; } | $NODE_BIN -e '
    let input = ""; process.stdin.on("data", c => input += c);
    process.stdin.on("end", () => {
      let d; try { d = JSON.parse(input); } catch { process.exit(0); }
      const ids = new Set();
      for (const v of Object.values(d.vulnerabilities || {})) {
        for (const via of v.via || []) {
          if (typeof via === "object" && via.url) {
            const m = via.url.match(/GHSA-[a-z0-9-]+/);
            if (m) ids.add(m[0]);
          }
        }
      }
      console.log([...ids].sort().join("\n"));
    });
  '
}

describe_ghsas() {
  local wanted_csv="$1"
  { $NPM_BIN audit --json 2>/dev/null || true; } | $NODE_BIN -e '
    let input = ""; process.stdin.on("data", c => input += c);
    process.stdin.on("end", () => {
      let d; try { d = JSON.parse(input); } catch { process.exit(0); }
      const wanted = new Set((process.argv[1] || "").split(",").filter(Boolean));
      const seen = new Set();
      for (const [pkg, v] of Object.entries(d.vulnerabilities || {})) {
        for (const via of v.via || []) {
          if (typeof via !== "object" || !via.url) continue;
          const m = via.url.match(/GHSA-[a-z0-9-]+/);
          if (!m || !wanted.has(m[0]) || seen.has(m[0])) continue;
          seen.add(m[0]);
          console.log(`  [${via.severity}] ${pkg}: ${via.title}`);
          console.log(`    ${via.url}`);
        }
      }
    });
  ' "$wanted_csv"
}

# ── Sync pi-agent (patches, extensions, config) ─────────────────────

prompt_pi_agent_git_url() {
  if [[ -n "${PI_AGENT_GIT_URL:-}" ]]; then
    printf '%s\n' "$PI_AGENT_GIT_URL"
    return 0
  fi
  if [[ -n "${JACK10_PI_AGENT_GIT_URL:-}" ]]; then
    printf '%s\n' "$JACK10_PI_AGENT_GIT_URL"
    return 0
  fi

  local target target_port target_path
  target="${PI_AGENT_SSH_TARGET:-${JACK10_PI_AGENT_TARGET:-${JACK10_SSH_TARGET:-}}}"
  target_port="${PI_AGENT_SSH_PORT:-${JACK10_PI_AGENT_PORT:-${JACK10_SSH_PORT:-}}}"
  target_path="${PI_AGENT_REPO_PATH:-${JACK10_PI_AGENT_REPO_PATH:-git/pi-agent.git}}"
  if [[ -n "$target" ]]; then
    jack10_git_ssh_url "$target" "$target_port" "$target_path"
    return 0
  fi

  local default_user default_port default_path user host port path
  default_user="$(whoami)"
  default_port="${JACK10_PI_AGENT_PORT:-${JACK10_SSH_PORT:-22}}"
  default_path="${JACK10_PI_AGENT_REPO_PATH:-git/pi-agent.git}"

  read -rp "pi-agent SSH user [$default_user]: " user
  user="${user:-$default_user}"

  read -rp "pi-agent SSH host: " host
  if [[ -z "$host" ]]; then
    echo "pi-agent SSH host is required." >&2
    return 1
  fi

  read -rp "pi-agent SSH port [$default_port]: " port
  port="${port:-$default_port}"

  read -rp "pi-agent repo path on host [$default_path]: " path
  path="${path:-$default_path}"

  if [[ "$path" = /* ]]; then
    printf 'ssh://%s@%s:%s%s\n' "$user" "$host" "$port" "$path"
  else
    printf 'ssh://%s@%s:%s/%s\n' "$user" "$host" "$port" "$path"
  fi
}

sync_pi_agent() {
  local agent_dir="$HOME/.pi/agent"

  if [[ -d "$agent_dir/.git" ]]; then
    echo "Pulling pi-agent from git..."
    if ! git -C "$agent_dir" pull --rebase --quiet; then
      echo "Error: failed to pull pi-agent repository. Check network or resolve conflicts." >&2
      return 1
    fi
  else
    local git_url
    git_url="$(prompt_pi_agent_git_url)"
    echo "Cloning pi-agent from $git_url ..."
    if [[ -e "$agent_dir" ]]; then
      local backup="$HOME/.local/state/pi-update/backups/pi-agent-$(date +%Y%m%d-%H%M%S)"
      mkdir -p "$(dirname "$backup")"
      cp -a "$agent_dir" "$backup"
      rm -rf "$agent_dir"
    fi
    mkdir -p "$(dirname "$agent_dir")"
    if ! git clone --quiet "$git_url" "$agent_dir"; then
      echo "Error: failed to clone pi-agent repository from $git_url" >&2
      return 1
    fi
  fi
}

# ── Report patches (no auto-apply) ──────────────────────────────────

report_patches() {
  if [[ -x "$SCRIPT_DIR/pi-patches" ]]; then
    "$SCRIPT_DIR/pi-patches" "$REPO" "$PATCHES_DIR"
    return 0
  fi

  if [[ ! -d "$PATCHES_DIR" ]]; then
    echo "No patches directory at $PATCHES_DIR"
    echo "Patches: none"
    return 0
  fi

  local patches=("$PATCHES_DIR"/*.patch)
  if [[ ! -f "${patches[0]}" ]]; then
    echo "No patch files found in $PATCHES_DIR"
    echo "Patches: none"
    return 0
  fi

  echo "Patches available at $PATCHES_DIR:"
  local any=0
  for patch in "${patches[@]}"; do
    local name; name="$(basename "$patch")"
    if git apply --check "$patch" 2>/dev/null; then
      echo "  ✅ $name  (applies cleanly)"
    else
      echo "  ❌ $name  (DOES NOT APPLY — upstream likely changed)"
    fi
    any=1
  done
  echo ""
  echo "Action required: review each patch above."
  echo "  - ✅ = remove if upstream has adopted the fix (check changelog)"
  echo "  - ❌ = regenerate patch (git diff) or drop if superseded"
  echo ""
}

# ── Main ─────────────────────────────────────────────────────────────

YES=false
REPAIR=false
for arg in "$@"; do
  case "$arg" in
    -y|--yes) YES=true ;;
    --repair) REPAIR=true ;;
    -h|--help)
      cat <<'EOF'
Usage: pi-update [--yes] [--repair]

Updates the local pi checkout to the latest release tag, syncs ~/.pi/agent,
updates pi packages, reports local patch status, rewrites the machine-local
launcher, and checks npm audit against the reviewed baseline.

  --yes     Do not prompt for upgrade/audit baseline confirmation
  --repair  Reinstall dependencies and rebuild even if already on latest tag
EOF
      exit 0
      ;;
    *)
      echo "Unknown argument: $arg" >&2
      exit 2
      ;;
  esac
done

echo "Fetching tags from origin..."
git fetch --tags --quiet origin

CURRENT="$(git describe --tags --exact-match 2>/dev/null || echo '<detached>')"
LATEST="$(git tag -l 'v*' --sort=-version:refname | head -1)"

if [[ -z "$LATEST" ]]; then
  echo "No version tags found." >&2
  exit 1
fi

if [[ "$CURRENT" == "$LATEST" ]]; then
  echo "Already on latest: $LATEST"
else
  echo "Current: $CURRENT"
  echo "Latest:  $LATEST"
  echo
  echo "Changes since $CURRENT:"
  if ! git log --oneline --no-decorate "${CURRENT}..${LATEST}" 2>/dev/null; then
    echo "  (unable to diff; showing recent history for $LATEST)"
    git log --oneline --no-decorate "$LATEST" -20
  fi
  echo

  if ! $YES; then
    read -rp "Upgrade to $LATEST? [y/N] " reply
    if [[ ! "$reply" =~ ^[yY]$ ]]; then
      echo "Aborted."
      exit 1
    fi
  fi

  echo "Checking out $LATEST..."
  git checkout --force --quiet "$LATEST"

  REPAIR=true
fi

# Sync pi-agent even when pi-mono is already on latest. Extensions, patches,
# settings, and auth-adjacent config can change independently of release tags.
sync_pi_agent

# Report patch status only. Patch reconciliation belongs to a live pi agent,
# not this bootstrap/update script.
report_patches

write_pi_launcher

if $REPAIR || needs_rebuild; then
  install_and_build
  echo
  echo "pi install/build complete. pi is at $LATEST"
else
  echo "Dependencies/build look present. Use --repair to force npm ci + build."
fi

echo
update_pi_packages

echo
echo "Checking npm audit against reviewed baseline..."

CURRENT_GHSAS="$(ghsa_ids_from_audit)"

if [[ ! -f "$BASELINE" ]]; then
  echo "No baseline file found — writing current state as initial baseline."
  printf '%s\n' "$CURRENT_GHSAS" > "$BASELINE"
  echo "Baseline: $BASELINE"
  exit 0
fi

NEW_GHSAS="$(comm -23 <(printf '%s\n' "$CURRENT_GHSAS") <(sort "$BASELINE") | sed '/^$/d')"

if [[ -z "$NEW_GHSAS" ]]; then
  echo "No new GHSA advisories."
  printf '%s\n' "$CURRENT_GHSAS" > "$BASELINE"
  exit 0
fi

echo "New GHSA advisories detected:"
printf '%s\n' "$NEW_GHSAS"
echo
describe_ghsas "$(printf '%s\n' "$NEW_GHSAS" | paste -sd, -)"
echo

if ! $YES; then
  read -rp "Mark these advisories as reviewed and update baseline? [y/N] " reply
  if [[ ! "$reply" =~ ^[yY]$ ]]; then
    echo "Leaving baseline unchanged: $BASELINE"
    exit 1
  fi
fi

printf '%s\n' "$CURRENT_GHSAS" > "$BASELINE"
echo "Baseline updated: $BASELINE"
